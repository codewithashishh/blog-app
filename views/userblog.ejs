<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>My Dashboard</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, Helvetica, sans-serif;
    }

    body{
      background:#f5f7fb;
      min-height:100vh;
    }

    .container{
      width:90%;
      max-width:1100px;
      margin:40px auto;
    }

    .header{
      background:#fff;
      padding:35px;
      border-radius:18px;
      display:flex;
      justify-content:space-between;
      align-items:center;
      box-shadow:0 10px 25px rgba(0,0,0,.08);
      margin-bottom:35px;
    }

    h1{
      color:#222;
      margin-bottom:8px;
    }

    .header p{
      color:#666;
      font-size:15px;
    }

    .actions{
      display:flex;
      gap:12px;
      align-items:center;
    }

    button{
      background:#6C63FF;
      color:white;
      border:none;
      padding:14px 28px;
      border-radius:10px;
      cursor:pointer;
      font-size:15px;
      transition:.3s;
    }

    button:hover{
      background:#574BDB;
    }

    .logout-btn{
      display:flex;
      align-items:center;
      justify-content:center;
      text-decoration:none;
      background:#ff4d4d;
      color:white;
      padding:14px 28px;
      border-radius:10px;
      transition:.3s;
    }

    .logout-btn:hover{
      background:#e63939;
    }

    .blogs{
      background:white;
      padding:30px;
      border-radius:18px;
      box-shadow:0 10px 25px rgba(0,0,0,.08);
    }

    .blogs h2{
      color:#222;
      margin-bottom:20px;
    }

    .empty{
      border:2px dashed #d8d8d8;
      border-radius:14px;
      padding:50px 20px;
      text-align:center;
      color:#777;
    }

    .empty h3{
      margin-bottom:10px;
      color:#333;
    }

    .empty p{
      margin-bottom:20px;
      line-height:1.6;
    }

    .emoji{
      font-size:55px;
      margin-bottom:15px;
    }

    .card{
      border:1px solid #e5e5e5;
      border-radius:12px;
      padding:20px;
      margin-bottom:20px;
    }

    .card h3{
      color:#222;
      margin-bottom:10px;
    }

    .card p{
      color:#555;
      line-height:1.6;
      margin-bottom:20px;
    }

    .card-actions{
      display:flex;
      gap:12px;
    }

    .card-actions form{
      margin:0;
    }

    .edit-btn{
      background:#28a745;
    }

    .edit-btn:hover{
      background:#218838;
    }

    .delete-btn{
      background:#dc3545;
    }

    .delete-btn:hover{
      background:#c82333;
    }

  </style>
</head>
<body>

<div class="container">

  <div class="header">

    <div>
      <h1>My Dashboard</h1>
      <p>Manage your blogs and start writing your next story.</p>
    </div>

    <div class="actions">

      <form action="/blog/createBlog" method="GET">
        <button type="submit">+ Create Blog</button>
      </form>

      <a href="/user/logout" class="logout-btn">
        Logout
      </a>

    </div>

  </div>

  <div class="blogs">

    <h2>Your Blogs</h2>

    <% if (blogs.length === 0) { %>

      <div class="empty">

        <div class="emoji">📝</div>

        <h3>No blogs yet</h3>

        <p>Start writing your first blog.</p>

        <form action="/blog/createBlog" method="GET">
          <button type="submit">Write Your First Blog</button>
        </form>

      </div>

    <% } else { %>

      <% blogs.forEach(blog => { %>

        <div class="card">

          <h3><%= blog.title %></h3>

          <p><%= blog.blog %></p>

          <div class="card-actions">

            <form action="/blog/edit/<%= blog._id %>" method="GET">
              <button type="submit" class="edit-btn">
                ✏️ Edit
              </button>
            </form>

            <form action="/blog/delete/<%= blog._id %>" method="POST">
              <button type="submit" class="delete-btn">
                🗑️ Delete
              </button>
            </form>

          </div>

        </div>

      <% }) %>

    <% } %>

  </div>

</div>

</body>
</html>