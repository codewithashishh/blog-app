<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Create Blog</title>

  <style>
    *{
      margin:0;
      padding:0;
      box-sizing:border-box;
      font-family:Arial, Helvetica, sans-serif;
    }

    body{
      background:#f5f7fb;
      display:flex;
      justify-content:center;
      align-items:center;
      min-height:100vh;
    }

    .container{
      width:90%;
      max-width:750px;
      background:#fff;
      padding:40px;
      border-radius:18px;
      box-shadow:0 10px 25px rgba(0,0,0,.08);
    }

    h1{
      color:#222;
      margin-bottom:10px;
    }

    p{
      color:#666;
      margin-bottom:30px;
    }

    label{
      display:block;
      margin-bottom:8px;
      font-weight:bold;
      color:#333;
    }

    input,
    textarea{
      width:100%;
      padding:14px;
      margin-bottom:25px;
      border:1px solid #dcdcdc;
      border-radius:10px;
      outline:none;
      font-size:15px;
    }

    input:focus,
    textarea:focus{
      border-color:#6C63FF;
    }

    textarea{
      min-height:250px;
      resize:vertical;
    }

    button{
      width:100%;
      padding:15px;
      border:none;
      border-radius:10px;
      background:#6C63FF;
      color:white;
      font-size:16px;
      cursor:pointer;
      transition:.3s;
    }

    button:hover{
      background:#574BDB;
    }
  </style>
</head>
<body>

<div class="container">

  <h1>Create New Blog</h1>
  <p>Share your thoughts, ideas, and stories with the community.</p>

  <form action="/blog/createBlog" method="POST">

    <label>Blog Title</label>
    <input
      type="text"
      name="title"
      placeholder="Enter your blog title"
      required
    >

    <label>Write Your Blog</label>
    <textarea
      name="blog"
      placeholder="Start writing here..."
      required
    ></textarea>

    <button type="submit">
      Publish Blog
    </button>

  </form>

</div>

</body>
</html>