<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>signup</title>
</head>
<body>
  <div>
    <form action="/user/login" method="post">
      <input type="text"
       name="name"
       required
       placeholder="name">
       <input type="text"
       name= "email"
       required
       placeholder="email">

       <input type="text"
       name="password"
       required
       placeholder="password">

       <button type="submit">Login</button>
    </form>
  </div>
</body>
